---
import { experience } from '../data/portfolio'
---

<section id="about" aria-labelledby="about-title" class="scroll-mt-6 px-5 py-24 sm:px-8 md:px-10 md:py-32">
  <div class="mx-auto max-w-6xl">
    <p class="section-kicker text-center">Perfil</p>
    <h2 id="about-title" data-route-heading tabindex="-1" class="hero-heading mt-5 text-center text-[clamp(3rem,12vw,9rem)] font-black uppercase leading-none">Sobre mí</h2>
    <p class="mx-auto mt-10 max-w-3xl text-center text-xl font-light leading-relaxed sm:text-2xl">
      Combino visión de producto y criterio técnico para que equipos, aplicaciones e infraestructura avancen en la misma dirección.
    </p>

    <dl class="mt-14 grid overflow-hidden rounded-[28px] border border-[#D7E2EA]/20 sm:grid-cols-3">
      <div data-reveal class="p-6 sm:p-8">
        <dt class="text-xs uppercase tracking-[.2em] opacity-60">Escala IoT</dt>
        <dd class="mt-3 text-3xl font-medium uppercase">Miles de dispositivos</dd>
      </div>
      <div data-reveal data-reveal-delay="80" class="border-t border-[#D7E2EA]/20 p-6 sm:border-l sm:border-t-0 sm:p-8">
        <dt class="text-xs uppercase tracking-[.2em] opacity-60">Infraestructura</dt>
        <dd class="mt-3 text-3xl font-medium uppercase">15+ servidores</dd>
      </div>
      <div data-reveal data-reveal-delay="160" class="border-t border-[#D7E2EA]/20 p-6 sm:border-l sm:border-t-0 sm:p-8">
        <dt class="text-xs uppercase tracking-[.2em] opacity-60">Alcance</dt>
        <dd class="mt-3 text-3xl font-medium uppercase">Producto a operación</dd>
      </div>
    </dl>

    <div class="mt-20 flex items-end justify-between gap-6 border-b border-[#D7E2EA]/20 pb-5">
      <h3 class="text-sm uppercase tracking-[.24em] opacity-60">Experiencia seleccionada</h3>
      <p class="hidden text-sm font-light opacity-60 sm:block">Dos etapas, una misma mirada integral.</p>
    </div>

    <div>
      {experience.map((entry, index) => (
        <article data-reveal data-reveal-delay={String(index * 90)} class="experience-row grid gap-6 border-b border-[#D7E2EA]/20 py-9 md:grid-cols-[10rem_minmax(14rem,.75fr)_1.25fr] md:gap-10">
          <p class="text-xs uppercase tracking-[.2em] opacity-60">{entry.stage}</p>
          <h4 class="text-2xl font-medium uppercase leading-tight">{entry.title}</h4>
          <div>
            <p class="font-light leading-relaxed opacity-80">{entry.description}</p>
            <ul aria-label={`Tecnologías de ${entry.title}`} class="mt-5 flex flex-wrap gap-2">
              {entry.stack.map(item => <li class="tag-dark">{item}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-5 sm:flex-row sm:items-center">
      <p class="max-w-xl text-lg font-light opacity-80">¿Necesitas conectar decisiones de negocio con una ejecución técnica sostenible?</p>
      <a class="button-light shrink-0" href="mailto:0865marc@gmail.com">Hablemos <span aria-hidden="true">↗</span></a>
    </div>
  </div>
</section>
