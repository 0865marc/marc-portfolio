---
import type { BlogPost } from '../data/blog'; interface Props { post: BlogPost }; const {post}=Astro.props
---
<article class="mx-auto max-w-3xl rounded-[28px] bg-white px-6 py-10 text-[#0C0C0C] sm:p-10 md:rounded-[40px] md:p-14">
  <p class="text-xs font-medium uppercase tracking-[.2em] opacity-60">{post.category}</p><h1 data-route-heading tabindex="-1" class="mt-6 break-words text-[clamp(2.5rem,7vw,5rem)] font-black uppercase leading-none">{post.title}</h1><p class="mt-8 text-xl font-light leading-relaxed opacity-70">{post.excerpt}</p>
  <ul class="mt-6 flex flex-wrap gap-2" aria-label="Etiquetas">{post.tags.map(tag=><li class="rounded-full border border-black/20 px-3 py-1.5 text-xs uppercase">{tag}</li>)}</ul>
  <div class="article-prose mt-12">{post.introduction.map(p=><p>{p}</p>)}{post.sections.map(section=><section><h2>{section.heading}</h2>{section.paragraphs.map(p=><p>{p}</p>)}{section.points && <ul>{section.points.map(point=><li>{point}</li>)}</ul>}</section>)}<aside>{post.takeaway.map(p=><p>{p}</p>)}</aside></div>
</article>
