---
import { projects } from '../data/portfolio'
---
<section id="projects" aria-labelledby="projects-title" class="scroll-mt-6 px-5 py-20 sm:px-8 md:px-10"><div class="mx-auto max-w-6xl"><h2 id="projects-title" tabindex="-1" class="hero-heading text-[clamp(3rem,12vw,10rem)] font-black uppercase leading-none">Proyectos</h2><div class="mt-16 space-y-8">{projects.map(project=><article data-project-card data-reveal class="rounded-[40px] border border-[#D7E2EA]/30 p-6 md:p-10"><p class="text-xs uppercase tracking-[.2em] opacity-60">{project.number} · {project.category}</p><h3 class="mt-5 text-4xl font-medium uppercase">{project.name}</h3><div class="mt-8 grid gap-4 md:grid-cols-3">{project.images.map((src,i)=><div class="aspect-video overflow-hidden rounded-[28px] bg-gradient-to-br from-[#1A1724] to-[#334554]"><img data-image-fallback src={src} alt={`Vista ${i+1} del proyecto ${project.name}`} width="1280" height="720" loading="lazy" decoding="async" class="h-full w-full object-cover" /></div>)}</div></article>)}</div><footer id="contact" class="scroll-mt-6 py-24"><h2 tabindex="-1" class="text-5xl font-black uppercase">¿Hablamos?</h2><address class="mt-8 not-italic"><a class="control" href="mailto:0865marc@gmail.com">0865marc@gmail.com</a> · <a class="control" href="https://linkedin.com/in/marc-teixid%C3%B3-rosauro">LinkedIn</a></address></footer></div></section>
