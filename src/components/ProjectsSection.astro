---
import { projects } from '../data/portfolio'

const currentYear = new Date().getFullYear()
---

<section id="projects" aria-labelledby="projects-title" class="scroll-mt-6 px-5 py-24 sm:px-8 md:px-10 md:py-32">
  <div class="mx-auto max-w-6xl">
    <div class="grid items-end gap-8 lg:grid-cols-[1fr_25rem]">
      <div>
        <p class="section-kicker">Trabajo seleccionado</p>
        <h2 id="projects-title" data-route-heading tabindex="-1" class="hero-heading mt-5 text-[clamp(3rem,12vw,9rem)] font-black uppercase leading-none">Proyectos</h2>
      </div>
      <p class="text-xl font-light leading-relaxed opacity-80">Productos y sistemas donde la experiencia visible depende de una base técnica bien resuelta.</p>
    </div>

    <div class="mt-16 space-y-6">
      {projects.map((project, projectIndex) => (
        <article data-project-card data-reveal data-reveal-delay={String(projectIndex * 80)} class="project-card rounded-[40px] border border-[#D7E2EA]/25 p-6 md:p-10">
          <div class="grid gap-7 md:grid-cols-[minmax(15rem,.8fr)_1.2fr] md:gap-12">
            <div>
              <p class="text-xs uppercase tracking-[.2em] opacity-60">{project.number} · {project.category}</p>
              <h3 class="mt-5 text-3xl font-medium uppercase leading-tight sm:text-4xl">{project.name}</h3>
            </div>
            <div>
              <p class="text-lg font-light leading-relaxed opacity-80">{project.description}</p>
              <p class="mt-5 text-xs uppercase tracking-[.18em] opacity-60">Enfoque · {project.focus}</p>
              <ul aria-label={`Áreas de ${project.name}`} class="mt-5 flex flex-wrap gap-2">
                {project.technologies.map(item => <li class="tag-dark">{item}</li>)}
              </ul>
            </div>
          </div>

          <div class="mt-9 grid gap-4 md:grid-cols-3">
            {project.images.map((src, imageIndex) => (
              <figure data-image-frame class="project-media relative aspect-video overflow-hidden rounded-[28px] bg-gradient-to-br from-[#1A1724] to-[#334554]">
                <img
                  data-image-fallback
                  src={src}
                  alt={`Vista ${imageIndex + 1} del proyecto ${project.name}`}
                  width="1280"
                  height="720"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                />
                <figcaption class="image-fallback-label absolute inset-0 hidden place-items-center px-5 text-center text-xs uppercase tracking-[.18em] opacity-60">Vista {imageIndex + 1} no disponible</figcaption>
                <span aria-hidden="true" class="project-media-index absolute bottom-3 right-3 rounded-full bg-[#0C0C0C]/75 px-2.5 py-1 text-[.65rem] uppercase tracking-[.14em]">0{imageIndex + 1}</span>
              </figure>
            ))}
          </div>
        </article>
      ))}
    </div>

    <footer id="contact" class="scroll-mt-6 pt-28 md:pt-36">
      <div data-contact-panel class="rounded-[40px] border border-[#D7E2EA]/25 p-6 sm:p-10 md:p-14">
        <p class="section-kicker">Siguiente proyecto</p>
        <div class="mt-5 grid min-w-0 gap-8 xl:grid-cols-[minmax(0,1fr)_minmax(0,24rem)] xl:items-end">
          <div class="contact-copy min-w-0">
            <h2 data-route-heading tabindex="-1" class="contact-heading hero-heading font-black uppercase leading-none tracking-[-.02em]">¿Hablamos?</h2>
            <p class="mt-7 max-w-2xl text-xl font-light leading-relaxed opacity-80">Si estás construyendo un producto conectado o necesitas ordenar su arquitectura y operación, cuéntame el contexto.</p>
          </div>
          <address class="flex min-w-0 w-full flex-col items-stretch gap-3 not-italic">
            <a class="contact-action button-light w-full max-w-full justify-between gap-4" href="mailto:0865marc@gmail.com">Escríbeme <span aria-hidden="true">↗</span></a>
            <a class="contact-action control w-full max-w-full justify-between gap-4" href="https://linkedin.com/in/marc-teixid%C3%B3-rosauro" rel="me">LinkedIn <span aria-hidden="true">↗</span></a>
          </address>
        </div>
      </div>
      <div class="flex flex-col gap-2 py-8 text-xs uppercase tracking-[.16em] opacity-60 sm:flex-row sm:items-center sm:justify-between">
        <p>Marc Teixidó · {currentYear}</p>
        <p>Producto · Software · Infraestructura</p>
      </div>
    </footer>
  </div>
</section>
