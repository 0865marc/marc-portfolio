---
import { services } from '../data/portfolio'
---
<section aria-labelledby="services-title" class="rounded-t-[40px] bg-white px-5 py-20 text-[#0C0C0C] sm:px-8 md:px-10"><h2 id="services-title" class="text-center text-[clamp(3rem,12vw,10rem)] font-black uppercase leading-none">Servicios</h2><div class="mx-auto mt-16 max-w-5xl">{services.map(service=><article data-reveal class="grid grid-cols-[72px_1fr] gap-4 border-t border-black/15 py-8 sm:grid-cols-[140px_1fr]"><p class="text-6xl font-black">{service.number}</p><div><h3 class="text-2xl font-medium uppercase">{service.name}</h3><p class="mt-3 font-light leading-relaxed opacity-60">{service.description}</p></div></article>)}</div></section>
