---
import Icon from './Icon.astro'
import { blogPostHref } from '../lib/blogRoutes'
import type { BlogPost } from '../data/blog'

interface Props {
  post: BlogPost
  source: 'landing' | 'index'
  headingLevel?: 2 | 3
}

const { post, source, headingLevel = 2 } = Astro.props
const Heading = `h${headingLevel}` as 'h2' | 'h3'
---

<article
  class="blog-card min-w-0"
  data-blog-card
  data-search={JSON.stringify({ id: post.id, title: post.title, excerpt: post.excerpt, category: post.category, tags: post.tags })}
  data-tags={post.tags.join('|')}
>
  <a
    href={blogPostHref(post.id, source)}
    aria-label={`Leer artículo: ${post.title}. Etiquetas: ${post.tags.join(', ')}`}
    class="blog-card-link group flex h-full min-h-[360px] flex-col justify-between rounded-[28px] border border-black/15 bg-white p-6 text-[#0C0C0C] sm:p-8"
  >
    <div>
      <p class="break-words text-xs font-medium uppercase tracking-[.2em] text-black/60">{post.category}</p>
      <Heading class="mt-7 break-words text-[clamp(1.35rem,2.4vw,2rem)] font-medium uppercase leading-tight">{post.title}</Heading>
      <p class="mt-5 font-light leading-relaxed text-black/65">{post.excerpt}</p>
      <ul aria-label="Etiquetas" class="mt-6 flex flex-wrap gap-2">
        {post.tags.map(tag => <li class="tag-light">{tag}</li>)}
      </ul>
    </div>
    <span class="blog-card-cta mt-8 inline-flex min-h-11 items-center gap-2 text-xs font-medium uppercase tracking-[.2em]">Leer artículo <Icon /></span>
  </a>
</article>
