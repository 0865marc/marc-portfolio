{
  "name": "marc-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:static": "vitest run tests/static-output.test.ts",
    "test:e2e": "playwright test",
    "test:container": "bash scripts/verify-container-image.sh",
    "measure:assets": "node scripts/measure-route-assets.mjs",
    "benchmark:lighthouse": "node scripts/benchmark-lighthouse.mjs",
    "test:ops": "bash tests/ops/nginx-activation.test.sh",
    "codegraph:init": "codegraph init",
    "codegraph:sync": "codegraph sync",
    "codegraph:status": "codegraph status --json",
    "verify:agents": "codegraph sync --quiet && codegraph status --json && python3 .agents/scripts/validate_design.py .agents/DESIGN.md && python3 -m unittest discover -s .agents/tests -p 'test_*.py' -v",
    "verify:workflow": "python3 .workflow/scripts/validate.py --project . && python3 -m unittest discover -s .workflow/tests -p 'test_*.py' -v",
    "verify": "npm run verify:agents && npm run verify:workflow && npm run check && npm run test:unit && npm run build && npm run test:static && npm run measure:assets && npm run test:ops"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@colbymchenry/codegraph": "1.5.0",
    "@playwright/test": "1.61.1",
    "astro": "7.1.3",
    "autoprefixer": "10.5.4",
    "lighthouse": "12.8.2",
    "postcss": "8.5.20",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
