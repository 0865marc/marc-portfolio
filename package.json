{
  "name": "marc-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro check && astro build",
    "preview": "astro preview --host 0.0.0.0",
    "check": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:static": "vitest run tests/static-output.test.ts",
    "test:e2e": "playwright test",
    "measure:assets": "node scripts/measure-route-assets.mjs",
    "benchmark:lighthouse": "node scripts/benchmark-lighthouse.mjs",
    "verify": "npm run check && npm run test:unit && npm run build && npm run test:static && npm run measure:assets"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "astro": "7.1.3",
    "autoprefixer": "10.5.4",
    "lighthouse": "12.8.2",
    "postcss": "8.5.20",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
